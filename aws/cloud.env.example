# Copy to cloud.env and fill in values. Deploy loads aws/cloud.env automatically
# (see aws/load-cloud-env.mjs). Do not commit cloud.env if it contains secrets.

# Required for pnpm deploy:prod — same Web client ID as VITE_GOOGLE_CLIENT_ID in webapp/.env
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional overrides (can also be set in the shell instead of this file)
# STACK_NAME=ovfs-prod
# ARTIFACT_BUCKET=your-unique-bucket-name
# AWS_REGION=us-east-1
# STAGE_NAME=prod
# ALLOWED_ORIGINS=https://your-app.example,https://www.your-app.example
# ACCOUNTS_TABLE_NAME=ovfs-prod-accounts
# ARTIFACT_PREFIX=ovfs-prod/
